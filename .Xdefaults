! $OpenBSD: dot.Xdefaults,v 1.3 2014/07/10 10:22:59 jasper Exp $

Xft.dpi: 102

Xcursor.theme: dmz
Xcursor.size: 32

*font: -misc-fixed-medium-r-*-*-20-*-*-*-*-*-iso10646-1

xterm*loginShell: true
xterm*internalBorder: 38
xterm*termName: xterm-256color
xterm*utmpInhibit: true
xterm*pointerMode: 2
xterm*allowSendEvents: true
xterm*metaSendsEscape: true
xterm*scrollBar: false
xterm*selectToClipboard: true
xterm.vt100.translations: #override\
	Meta <KeyPress> V: insert-selection(CLIPBOARD, PRIMARY, CUT_BUFFER0)\n\
	Super <KeyPress> V: insert-selection(CLIPBOARD, PRIMARY, CUT_BUFFER0)
xterm*geometry: 80x40

xclock*update: 1
xclock*analog: false
xclock*render: true
xclock*padding: 40
xclock*face: vga-28
xclock*strftime: %a %b %d  %H:%M
