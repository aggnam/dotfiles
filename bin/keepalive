#!/bin/sh

case "$1" in
	enable)
		if [ ! X`pgrep xidle` = X"" ]; then
			pkill -9 xidle
			echo "keepalive"
		fi
		;;
	disable)
		if [ ! X`pgrep xidle` = X"" ]; then
			echo "keepalive already disabled"
		else
			xidle -timeout 300 -program ~/bin/lock &
			echo "nokeepalive"
		fi
		;;
	toggle)
		if [ ! X`pgrep xidle` = X"" ]; then
			"$0" enable
		else
			"$0" disable
		fi
		;;
	status)
		if [ ! X`pgrep xidle` = X"" ]; then
      		echo "keepalive disabled (xidle at: `pgrep xidle`)"
    	else
      		echo "keepalive enabled"
    	fi
    	;;
	*)
		echo "Usage: $0 {enable|disable|toggle|status}"
		exit 1
		;;
esac
