#!/bin/sh

CMUS="cmus"
AUDACIOUS="audacious"

PLAYER=""
if [ ! X`pgrep cmus | sed -n '1p'` = X"" ]; then
	PLAYER=$CMUS
elif [ ! X`pgrep audacious` = X"" ]; then
	PLAYER=$AUDACIOUS
else
	echo "no music player"
	exit 1
fi

case "$1" in
next)
	case $PLAYER in
	$CMUS)
		cmus-remote -n
		;;
	$AUDACIOUS)
		audtool playlist-advance
		;;
	esac
	;;
nextalbum)
	case $PLAYER in
	$CMUS)
		cmus-remote -C "player-next-album"
		;;
	$AUDACIOUS)
		audtool playlist-advance-album
		;;
	esac
	;;
prev)
	case $PLAYER in
	$CMUS)
		cmus-remote -r
		;;
	$AUDACIOUS)
		audtool playlist-reverse
		;;
	esac
	;;
prevalbum)
	case $PLAYER in
	$CMUS)
		cmus-remote -C "player-prev-album"
		;;
	$AUDACIOUS)
		audtool playlist-reverse-album
		;;
	esac
	;;
pause)
	case $PLAYER in
	$CMUS)
		cmus-remote -U
		;;
	$AUDACIOUS)
		# "audtool playback-pause" should just pause, but it stupidly inverts
		# playing status so we need to check if it's both playing and not
		# paused
		if [ `audtool playback-status` == "playing" ]; then
			audtool playback-pause
		fi
		;;
	esac
	;;
playpause)
	case $PLAYER in
	$CMUS)
		cmus-remote -u
		;;
	$AUDACIOUS)
		audtool playback-playpause
		;;
	esac
	;;
np)
	case $PLAYER in
	$CMUS)
		cmus-remote -Q |
			awk '
			$2=="title"        { $1=$2=""; sub(/^  */, ""); title=$0 }
			$2=="albumartist"  { $1=$2=""; sub(/^  */, ""); artist=$0 }
			$2=="album"        { $1=$2=""; sub(/^  */, ""); album=$0 }
			END {
				print "now playing: " title " by " artist " on " album
			}'
		;;
	$AUDACIOUS)
		# not yet
		audtool --current-song
		;;
	esac
	;;
*)
	echo "unknown command \"${1}\""
	exit 1
	;;
esac
