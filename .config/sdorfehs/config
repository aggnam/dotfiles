set barsticky 0
set bargravity c
set barpadding 12 8
set border 3
set font "comic mono:size=13"
set gap 2
set ignoreresizehints 1
set padding 5 5 5 5
set startupmessage 0

bind c exec urxvt
bind C-c exec urxvt

# lock the screen
bind L exec pkill -USR1 xidle

# web development view, split firefox and a terminal
bind W exec sdorfehs -c "hsplit" -c "resize 200 0"

# prevent accidental closes
unbind k

# swap workspaces, but define it in 'top' to avoid having to prefix with C-a
set vscreens 4
definekey top M-1 vselect 0
definekey top M-2 vselect 1
definekey top M-3 vselect 2
definekey top M-4 vselect 3

# map to F keys
definekey top F1 exec sdorfehs -c "echo vol: `~/bin/volume mute`"
definekey top F2 exec sdorfehs -c "echo vol: `~/bin/volume down`"
definekey top F3 exec sdorfehs -c "echo vol: `~/bin/volume up`"

definekey top F10 exec ~/bin/music prev
definekey top F11 exec ~/bin/music playpause
definekey top F12 exec ~/bin/music next
definekey top M-F12 exec ~/bin/music nextalbum

definekey top Print exec ~/bin/screenshot

# sometime i need the screen to keep alive
definekey top F9 exec sdorfehs -c "echo `~/bin/keepalive toggle`"

# i like tab just going between the same two window
bind Tab focuslast
bind grave focus

# startup configuration
hsplit
exec urxvt
